# Copia in .env.local — MAI committare su GitHub

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

VITE_APP_NAME=Boscolo Luca
VITE_APP_URL=https://PLACEHOLDER.it
VITE_APP_TAGLINE=Consulente Assicurativo in Provincia di Varese

VITE_CONTACT_EMAIL=PLACEHOLDER@email.com

# Abilita area admin (true/false)
VITE_ENABLE_ADMIN=false

# Supabase Edge Function Secrets (impostare via: supabase secrets set RESEND_API_KEY=xxx)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# FROM_EMAIL=noreply@tuodominio.com
